#!/bin/sh
# chaldos-config — ChaldOS configuration tool
# ============================================

CONFIG_FILE="/etc/chaldos.conf"
[[ -f "$CONFIG_FILE" ]] || CONFIG_FILE="/root/.chaldosrc"
[[ -f "$CONFIG_FILE" ]] || CONFIG_FILE="/home/chaldos/.chaldosrc"

. /usr/lib/chaldos/libchaldos.sh

show_config() {
    chaldos_header "Current Configuration"
    if [[ -f "$CONFIG_FILE" ]]; then
        cat "$CONFIG_FILE"
    else
        echo "No configuration file found."
    fi
}

set_config() {
    local key="$1" value="$2"
    if [[ ! -f /etc/chaldos.conf ]]; then
        echo "# ChaldOS User Configuration" > /etc/chaldos.conf
        echo "# Generated by chaldos-config" >> /etc/chaldos.conf
    fi
    if grep -q "^${key}=" /etc/chaldos.conf; then
        sed -i "s/^${key}=.*/${key}=${value}/" /etc/chaldos.conf
    else
        echo "${key}=${value}" >> /etc/chaldos.conf
    fi
    chaldos_log "${key} set to ${value}"
}

case "${1:-show}" in
    show|status)
        show_config
        ;;
    set)
        if [[ $# -lt 3 ]]; then
            echo "Usage: chaldos-config set <key> <value>"
            echo "Keys: hostname, wallpaper, theme, resolution"
            exit 1
        fi
        set_config "$2" "$3"
        ;;
    hostname)
        local newname="${2:-chaldos}"
        set_config "hostname" "$newname"
        hostname "$newname" 2>/dev/null || true
        echo "$newname" > /etc/hostname 2>/dev/null || true
        chaldos_log "Hostname set to ${newname}"
        ;;
    reset)
        rm -f /etc/chaldos.conf
        chaldos_log "Configuration reset to defaults"
        ;;
    help|--help|-h)
        echo "ChaldOS Configuration Tool"
        echo "Usage: chaldos-config [command]"
        echo ""
        echo "Commands:"
        echo "  show                Display current configuration"
        echo "  set <key> <value>   Set a config value"
        echo "  hostname <name>     Set system hostname"
        echo "  reset               Reset to defaults"
        echo "  help                Show this help"
        ;;
    *)
        echo "Usage: chaldos-config {show|set|hostname|reset}"
        exit 1
        ;;
esac
