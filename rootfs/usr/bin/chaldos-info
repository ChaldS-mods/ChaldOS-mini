#!/bin/sh
# chaldos-info — Display ChaldOS system information
# ==================================================

CHALDOS_VERSION="1.0.0"
CHALDOS_CODENAME="Pixel Dawn"

# Source library
. /usr/lib/chaldos/libchaldos.sh 2>/dev/null || true

echo ""
chaldos_header "ChaldOS System Information"

echo -e " ${C_BOLD}OS:${C_RESET}       ChaldOS ${CHALDOS_VERSION} \"${CHALDOS_CODENAME}\""
echo -e " ${C_BOLD}Kernel:${C_RESET}   $(uname -r)"
echo -e " ${C_BOLD}Arch:${C_RESET}     $(uname -m)"
echo -e " ${C_BOLD}Uptime:${C_RESET}   $(chaldos_uptime)"
echo -e " ${C_BOLD}CPU:${C_RESET}      $(chaldos_cpuinfo)"
echo -e " ${C_BOLD}Memory:${C_RESET}   $(chaldos_meminfo)"
echo -e " ${C_BOLD}Host:${C_RESET}     $(hostname)"

# Network info
echo -e " ${C_BOLD}Network:${C_RESET}"
for iface in /sys/class/net/*; do
    name=$(basename "$iface")
    [[ "$name" = "lo" ]] && continue
    mac=$(cat "${iface}/address" 2>/dev/null || echo "N/A")
    ip=$(ip -4 addr show "$name" 2>/dev/null | grep inet | awk '{print $2}' | head -1 || echo "N/A")
    echo -e "    ${C_YELLOW}${name}${C_RESET}: ${ip} (MAC: ${mac})"
done

# Display info
echo -e " ${C_BOLD}Displays:${C_RESET}"
for fb in /sys/class/graphics/fb*; do
    [[ -e "$fb" ]] || continue
    fbn=$(basename "$fb")
    res=$(cat "${fb}/virtual_size" 2>/dev/null || echo "unknown")
    bits=$(cat "${fb}/bits_per_pixel" 2>/dev/null || echo "?")
    echo -e "    ${C_YELLOW}${fbn}${C_RESET}: ${res} @${bits}bpp"
done

echo ""
