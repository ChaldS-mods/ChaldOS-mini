#!/bin/sh
# ChaldOS rcS — system initialization script
# =============================================
# This runs at boot before any login prompt.

PATH="/sbin:/bin:/usr/sbin:/usr/bin"

echo "[ChaldOS] Initializing..."

# Mount pseudo-filesystems
mount -t proc none /proc 2>/dev/null || true
mount -t sysfs none /sys 2>/dev/null || true
mount -t devtmpfs none /dev 2>/dev/null || true
mount -t tmpfs none /tmp 2>/dev/null || true
mount -t tmpfs none /run 2>/dev/null || true

# Create essential device nodes (if devtmpfs not available)
if [[ ! -e /dev/null ]]; then
    mknod /dev/null c 1 3
    mknod /dev/zero c 1 5
    mknod /dev/random c 1 8
    mknod /dev/urandom c 1 9
    mknod /dev/tty c 5 0
    mknod /dev/console c 5 1
    chmod 666 /dev/null /dev/zero /dev/tty
fi

# Create essential directories
mkdir -p /dev/pts /dev/shm /var/log /var/run /var/lock
mount -t devpts none /dev/pts 2>/dev/null || true

# Set hostname
hostname -F /etc/hostname 2>/dev/null || hostname chaldos

# Configure loopback network
ip link set lo up 2>/dev/null || true

# Load kernel modules
[[ -x /etc/init.d/modules ]] && /etc/init.d/modules

# Start networking
[[ -x /etc/init.d/network ]] && /etc/init.d/network

# Set up framebuffer for display
if [[ -d /sys/class/graphics/fb0 ]]; then
    echo "[ChaldOS] Framebuffer detected"
else
    echo "[ChaldOS] No framebuffer — running headless"
fi

# Initialize random seed
if [[ -f /var/lib/random-seed ]]; then
    cat /var/lib/random-seed > /dev/urandom 2>/dev/null || true
fi
dd if=/dev/urandom of=/var/lib/random-seed bs=512 count=1 2>/dev/null || true

# Start system logger
syslogd 2>/dev/null || true

# Start udev for device management (needed by Wayland/libinput)
if command -v udevd &>/dev/null && command -v udevadm &>/dev/null; then
    # Start udev daemon
    udevd -d 2>/dev/null || true
    # Trigger events for already-connected devices
    udevadm trigger --type=subsystems --action=add 2>/dev/null || true
    udevadm trigger --type=devices --action=add 2>/dev/null || true
    # Wait for initial device processing
    udevadm settle -t 3 2>/dev/null || true
    echo "[ChaldOS] udev started"
fi

# Load desktop mode configuration
if [ -f /etc/chaldos/de.conf ]; then
    . /etc/chaldos/de.conf 2>/dev/null
    echo "[ChaldOS] Desktop mode: ${CHALDOS_DE:-console}"
fi

echo "[ChaldOS] System ready."
echo "[ChaldOS] Welcome to ChaldOS! Type 'help' for commands."
